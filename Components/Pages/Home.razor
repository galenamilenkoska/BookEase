@page "/"
<PageTitle>BookEase – Premium Barbershop</PageTitle>

<section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content container">
        <div class="hero-badge">Est. 2018 · Premium Grooming</div>
        <h1 class="hero-title">Expert Cuts,<br /><span class="hero-title-accent">Unbeatable Style</span></h1>
        <p class="hero-subtitle">Professional barbershop services tailored to you. Walk in looking good, walk out looking great.</p>
        <div class="hero-actions">
            <a href="/book" class="btn-hero-primary">Book an Appointment</a>
            <a href="#services" class="btn-hero-secondary">See Our Services</a>
        </div>
    </div>
</section>

<section class="services-section" id="services">
    <div class="container">
        <div class="section-header text-center">
            <h2 class="section-title">Our Services</h2>
            <p class="section-subtitle">Every visit is a fresh start. Choose the service that's right for you.</p>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">💈</div>
                <div class="service-body">
                    <h3 class="service-name">Classic Haircut</h3>
                    <p class="service-desc">A timeless cut tailored to your personal style. Includes consultation, wash, cut, and finish.</p>
                    <div class="service-meta">
                        <span class="service-duration">⏱ 30 min</span>
                        <span class="service-price">$25.00</span>
                    </div>
                </div>
                <a href="/book?serviceId=1" class="btn-book-service">Book This Service</a>
            </div>
            <div class="service-card">
                <div class="service-icon">🪒</div>
                <div class="service-body">
                    <h3 class="service-name">Beard Trim &amp; Shape</h3>
                    <p class="service-desc">Precision beard grooming and sculpting to keep your beard looking sharp and well-defined.</p>
                    <div class="service-meta">
                        <span class="service-duration">⏱ 30 min</span>
                        <span class="service-price">$18.00</span>
                    </div>
                </div>
                <a href="/book?serviceId=2" class="btn-book-service">Book This Service</a>
            </div>
            <div class="service-card service-card-featured">
                <div class="service-badge-popular">Most Popular</div>
                <div class="service-icon">✂️</div>
                <div class="service-body">
                    <h3 class="service-name">Haircut &amp; Beard Combo</h3>
                    <p class="service-desc">Our most popular service — a full haircut paired with a professional beard trim and shape.</p>
                    <div class="service-meta">
                        <span class="service-duration">⏱ 60 min</span>
                        <span class="service-price">$38.00</span>
                    </div>
                </div>
                <a href="/book?serviceId=3" class="btn-book-service">Book This Service</a>
            </div>
            <div class="service-card">
                <div class="service-icon">🔥</div>
                <div class="service-body">
                    <h3 class="service-name">Hot Towel Shave</h3>
                    <p class="service-desc">Traditional straight-razor shave with warm towel prep, premium shave cream, and soothing aftercare.</p>
                    <div class="service-meta">
                        <span class="service-duration">⏱ 45 min</span>
                        <span class="service-price">$30.00</span>
                    </div>
                </div>
                <a href="/book?serviceId=4" class="btn-book-service">Book This Service</a>
            </div>
        </div>
    </div>
</section>

<section class="why-section">
    <div class="container">
        <div class="why-grid">
            <div class="why-item">
                <div class="why-icon">🏆</div>
                <h4>Expert Barbers</h4>
                <p>Highly trained professionals with years of experience in classic and modern styles.</p>
            </div>
            <div class="why-item">
                <div class="why-icon">📅</div>
                <h4>Easy Booking</h4>
                <p>Book your appointment in seconds online — no phone calls, no waiting.</p>
            </div>
            <div class="why-item">
                <div class="why-icon">⭐</div>
                <h4>Premium Products</h4>
                <p>We use only top-tier grooming products for the best results every time.</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container text-center">
        <h2 class="cta-title">Ready for a fresh look?</h2>
        <p class="cta-subtitle">Book your next appointment today and leave looking your best.</p>
        <a href="/book" class="btn-cta">Book Your Appointment</a>
    </div>
</section>
